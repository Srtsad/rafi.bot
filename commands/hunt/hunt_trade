PRICES = {
    "патроны": 50000,
    "жилет": 120000,
    "нож": 90000,
    "прицел": 200000
}

# =========================
# КУПИТЬ ПРЕДМЕТ
# =========================
@router.message(F.text.lower().startswith("купить"))
async def buy_item(message: types.Message):
    text = message.text.lower().strip()
    player = get_player(message.from_user.id)
    db = load_db()
    uid = str(message.from_user.id)

    if uid not in db:
        return await message.answer("Напиши: охота")

    user = db[uid]
    if "buffs" not in user:
        user["buffs"] = {}

    # ========= ПАТРОНЫ =========
    if "патроны" in text:
        price = PRICES["патроны"]
        if player["money"] < price:
            return await message.answer("❌ Не хватает денег")
        player["money"] -= price
        user["ammo"] = user.get("ammo", 0) + 10
        save_player(message.from_user.id, player)
        save_db(db)
        return await message.answer("🔫 Куплено 10 патронов")

    # ========= ЖИЛЕТ =========
    if "жилет" in text:
        price = PRICES["жилет"]
        if player["money"] < price:
            return await message.answer("❌ Не хватает денег")
        player["money"] -= price
        user["buffs"]["vest"] = int(time.time()) + 3600
        save_player(message.from_user.id, player)
        save_db(db)
        return await message.answer("🧥 Куплен жилет (1 час бонус)")

    # ========= НОЖ =========
    if "нож" in text:
        price = PRICES["нож"]
        if player["money"] < price:
            return await message.answer("❌ Не хватает денег")
        player["money"] -= price
        user["buffs"]["knife"] = int(time.time()) + 3600
        save_player(message.from_user.id, player)
        save_db(db)
        return await message.answer("🔪 Куплен нож (1 час бонус)")

    # ========= ПРИЦЕЛ =========
    if "прицел" in text:
        price = PRICES["прицел"]
        if player["money"] < price:
            return await message.answer("❌ Не хватает денег")
        player["money"] -= price
        user["buffs"]["scope"] = int(time.time()) + 3600
        save_player(message.from_user.id, player)
        save_db(db)
        return await message.answer("🎯 Куплен прицел (1 час бонус)")

    await message.answer("❌ Предмет не найден")

