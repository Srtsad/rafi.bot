# ПРОДАТЬ КОНКРЕТНО
# пример: продать мясо
# =========================
@router.message(F.text.lower().startswith("продать "))
async def sell_item(message: types.Message):
    name = message.text[8:].strip()
    db = load_db()
    uid = str(message.from_user.id)
    if uid not in db:
        return

    user = db[uid]
    player = get_player(message.from_user.id)
    found = None
    for item in user.get("loot", {}):
        if name.lower() in item.lower():
            found = item
            break
    if not found:
        return await message.answer("❌ Нет такой добычи")

    qty = user["loot"][found]
    PRICE_LIST = {
        "🥩 Мясо":25,
        "🦴 Кости зверя":18,
        "🪶 Перья":12,
        "🦌 Обычная шкура":120,
        "🐗 Клык дикого вепря":900,
        "🐺 Шкура волка":480,
        "🦅 Перо беркута":1100,
        "🐻 Коготь медведя":1200,
        "🦌 Рога оленя":600,
        "🐺 Шкура альфа-волка":2500,
        "🦌 Рога матёрого оленя":1800,
        "🐆 Шкура рыси":2900,
        "👑 Голова альфа-волка":6000,
        "🌟 Легендарная шкура зверя":8500,
    }
    price = PRICE_LIST.get(found, 0) * qty
    del user["loot"][found]
    player["money"] += price
    save_player(message.from_user.id, player)
    save_db(db)
    await message.answer(f"💰 Продано {found} ×{qty} за {price}$")
