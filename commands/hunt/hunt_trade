@router.message(F.text.lower().in_(["продать всё","продать все"]))
async def sell_all(message: types.Message):
    db = load_db()
    uid = str(message.from_user.id)
    if uid not in db:
        return

    user = db[uid]
    player = get_player(message.from_user.id)
    if not user.get("loot"):
        return await message.answer("❌ Нет добычи")

    total = 0
    PRICE_LIST = {
        "🥩 Мясо":25,
        "🦴 Кости зверя":18,
        "🪶 Перья":12,
        "🦌 Обычная шкура":120,
        "🐗 Клык дикого вепря":900,
        "🐺 Шкура волка":480,
        "🦅 Перо беркута":1100,
        "🐻 Коготь медведя":1200,
        "🦌 Рога оленя":600,
        "🐺 Шкура альфа-волка":2500,
        "🦌 Рога матёрого оленя":1800,
        "🐆 Шкура рыси":2900,
        "👑 Голова альфа-волка":6000,
        "🌟 Легендарная шкура зверя":8500,
    }

    for item, qty in user["loot"].items():
        if item in PRICE_LIST:
            total += PRICE_LIST[item] * qty

    user["loot"] = {}
    player["money"] += total
    save_player(message.from_user.id, player)
    save_db(db)
    await message.answer(f"💰 Продано всё за {total}$")

