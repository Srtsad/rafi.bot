@router.message(F.text.lower() == "стрелять")
async def shoot(message: types.Message):
    db = load_db()
    uid = str(message.from_user.id)

    if uid not in db:
        return await message.answer("Напиши: охота")

    user = db[uid]

    # Проверка патронов
    if user.get("ammo", 0) <= 0:
        return await message.answer("❌ Нет патронов")
    user["ammo"] -= 1

    # ================= Легендарные события =================
    if random.randint(1, 100) <= 5:
        legendary_events = [
            ("🌲 Легендарный медведь Шишка напал!", ["🐻 Шкура волка"]),
            ("❗ Белый медведь напал!", ["🐾 Клык белого медведя"]),
            ("💠 Безрыкий устрашает стаю волков.", ["🐺 Шкура волка", "🐗 Клык вепря"]),
            ("🔥 Легендарная рысь ловит добычу!", ["🐆 Шкура рыси"]),
            ("🌟 Легендарный олень с золотыми рогами.", ["🦌 Рога матёрого оленя"])
        ]
        msg, items = random.choice(legendary_events)
        for item in items:
            user["loot"][item] = user["loot"].get(item, 0) + 1
            add_loot_to_top(uid, message.from_user.username or f"Игрок_{uid}", "легендарка")
        save_db(db)
        await message.answer(f"{msg}\n\n🎁 Добыча: {', '.join(items)}")
        return

    # ================= Определяем редкость с бонусами =================
    bonus = 0
    now = int(time.time())
    boosts = user.get("boosts", {})

    if boosts.get("knife", 0) > now: bonus += 5
    if boosts.get("vest", 0) > now: bonus += 5
    if boosts.get("scope", 0) > now: bonus += 10
    if boosts.get("bait", 0) > now: bonus += 15
    if boosts.get("gun", 0) > now: bonus += 20

    roll = random.randint(1, 100) + bonus

    if roll <= 60:
        rarity = "обычная"
    elif roll <= 85:
        rarity = "редкая"
    elif roll <= 95:
        rarity = "эпик"
    elif roll <= 99:
        rarity = "мифик"
    else:
        rarity = "легендарка"

    # Выбор предмета
    event = random.choice(LOOT_EVENTS[rarity])
    msg, item_name = event

    # Добавляем добычу игроку
    user["loot"][item_name] = user["loot"].get(item_name, 0) + 1
    user["kills"] = user.get("kills", 0) + 1
    save_db(db)
    add_loot_to_top(uid, message.from_user.username or f"Игрок_{uid}", rarity)

    await message.answer(f"{msg}\n\n🎁 Добыча: {item_name}")

