def build_profile(uid, tg_user):
    db = load_db()
    if uid not in db:
        db[uid] = {"ammo": 0, "loot": {}, "kills": 0}
        save_db(db)
    user = db[uid]
    mention = get_mention(tg_user.id, tg_user.username)
    loot_text = "\n".join(f"{item} ×{qty}" for item, qty in user["loot"].items()) or "Нет добычи"

    # ===== бусты =====
    now = int(time.time())
    boosts_text = ""
    for b, end in user.get("boosts", {}).items():
        if end > now:
            names = {
                "knife": "🔪 нож",
                "vest": "🦺 жилет",
                "scope": "🎯 прицел",
                "bait": "🪤 приманка",
                "gun": "💥 проф ружье"
            }
            mins = int((end - now) / 60)
            boosts_text += f"{names.get(b, b)} — {mins} мин\n"
    if not boosts_text:
        boosts_text = "нет"

    # ===== сборка текста =====
    text = (
        f"🏹 <b>ПРОФИЛЬ ОХОТНИКА</b>\n"
        f"━━━━━━━━━━━━━━\n"
        f"👤 Игрок: {mention}\n"
        f"🔫 Патроны: {user['ammo']}\n\n"
        f"🦌 Добыча:\n{loot_text}\n"
        f"━━━━━━━━━━━━━━\n"
        f"⚡ Активные бусты:\n{boosts_text}"
        f"━━━━━━━━━━━━━━"
    )
    return text

@router.message(F.text.lower().in_(["охота","профиль охотника"]))
async def hunt_profile(message: types.Message):
    uid = str(message.from_user.id)
    text = build_profile(uid, message.from_user)
    await message.answer(text, reply_markup=profile_kb(), parse_mode="HTML")

@router.callback_query(F.data=="back_profile")
async def back_profile(call: CallbackQuery):
    uid = str(call.from_user.id)
    text = build_profile(uid, call.from_user)
    await call.message.edit_text(text, reply_markup=profile_kb(), parse_mode="HTML")

