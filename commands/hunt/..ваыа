# =========================
@router.message(lambda m: m.text and m.text.lower().startswith("купить"))
async def buy_hunt(message: types.Message):
    uid = str(message.from_user.id)
    db = load_db()

    if uid not in db:
        return await message.answer("Напиши: охота")

    user = db[uid]
    player = get_player(message.from_user.id)

    if "boosts" not in user:
        user["boosts"] = {}

    args = message.text.lower().split()

    # ❗ если просто "купить"
    if len(args) < 2:
        return

    # ❗ ЕСЛИ ПОКУПАЮТ СТАТУС — НЕ ТРОГАЕМ (другой скрипт обработает)
    if args[1] == "статус":
        return

    # =========================
    # КУПИТЬ ПАТРОНЫ
    # =========================
    if len(args) >= 3 and args[1] == "патроны":
        try:
            amount = int(args[2])
        except:
            return await message.answer("❌ Пример: купить патроны 100")

        price = amount * 1000  # цена за 1 патрон

        if player["money"] < price:
            return await message.answer("❌ Недостаточно денег")

        player["money"] -= price
        user["ammo"] += amount

        save_player(message.from_user.id, player)
        save_db(db)

        return await message.answer(f"🔫 Куплено патронов: {amount}")

    # =========================
    # КУПИТЬ БУСТ
    # =========================
    item_input = args[1]

    if item_input not in BOOSTS:
        return await message.answer("❌ Такого буста нет")

    boost = BOOSTS[item_input]

    price = boost.get("price", 1000)
    if player["money"] < price:
        return await message.answer("❌ Недостаточно денег")

    player["money"] -= price
    save_player(message.from_user.id, player)

    now = int(time.time())
    user["boosts"][boost["key"]] = now + BOOST_TIME

    save_db(db)

    await message.answer(f"⚡ Буст {item_input} активирован на 60 мин")

